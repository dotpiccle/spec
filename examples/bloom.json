{
  "$schema": "https://spec.dotpiccle.com/schema/v1.json",
  "piccle": "1.0",
  "name": "Bloom",
  "description": "Two almost-identical tones a few cents apart — a warm, slow swell.",
  "reverb": {
    "amount": 0.3,
    "tail_ms": 400,
    "soften_hz": 4000
  },
  "layers": [
    {
      "id": "tone-a",
      "start_ms": 0,
      "duration_ms": 600,
      "source": {
        "type": "tone",
        "wave": "sine",
        "pitch": {
          "frequencies": [
            {
              "hz": 528
            }
          ],
          "offset_cents": 0
        }
      },
      "volume": {
        "fade_in_ms": 80,
        "fade_out_ms": 100,
        "levels": [
          {
            "level": 0.4,
            "hold_ms": 200,
            "transition_ms": 0,
            "transition_curve": "linear"
          },
          {
            "level": 0.4
          }
        ]
      }
    },
    {
      "id": "tone-b",
      "start_ms": 0,
      "duration_ms": 600,
      "source": {
        "type": "tone",
        "wave": "sine",
        "pitch": {
          "frequencies": [
            {
              "hz": 528
            }
          ],
          "offset_cents": 12
        }
      },
      "volume": {
        "fade_in_ms": 80,
        "fade_out_ms": 100,
        "levels": [
          {
            "level": 0.3,
            "hold_ms": 200,
            "transition_ms": 0,
            "transition_curve": "linear"
          },
          {
            "level": 0.3
          }
        ]
      }
    }
  ]
}
