{
  "$schema": "https://spec.dotpiccle.com/schema/v1.json",
  "piccle": "1.0",
  "name": "Toggle Off",
  "description": "A soft falling tone with a tiny noise tick underneath — for toggles switching off.",
  "layers": [
    {
      "id": "tone",
      "start_ms": 0,
      "duration_ms": 150,
      "source": {
        "type": "tone",
        "wave": "sine",
        "pitch": {
          "frequencies": [
            {
              "hz": 800,
              "hold_ms": 0,
              "transition_ms": 100,
              "transition_curve": "linear"
            },
            {
              "hz": 400
            }
          ]
        }
      },
      "volume": {
        "fade_in_ms": 2,
        "fade_out_ms": 10,
        "levels": [
          {
            "level": 0.5,
            "hold_ms": 0,
            "transition_ms": 30,
            "transition_curve": "exponential"
          },
          {
            "level": 0.15
          }
        ]
      }
    },
    {
      "id": "tick",
      "start_ms": 0,
      "duration_ms": 30,
      "source": {
        "type": "noise",
        "character": "neutral"
      },
      "volume": 0.3,
      "filters": [
        {
          "type": "highpass",
          "frequencies": [
            {
              "hz": 4000
            }
          ],
          "resonance": 0
        }
      ]
    }
  ]
}
