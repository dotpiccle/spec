      "volume": {
        "fade_in_ms": 10,
        "fade_out_ms": 50,
        "levels": [
          {
            "level": 0.25,
            "hold_ms": 0,
            "transition_ms": 40,
            "transition_curve": "exponential"
          },
          {
            "level": 0.04
          }
        ]
      }
    }
  ]
}
