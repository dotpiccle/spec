      "volume": {
        "fade_in_ms": 5,
        "fade_out_ms": 40,
        "levels": [
          {
            "level": 0.3,
            "hold_ms": 0,
            "transition_ms": 80,
            "transition_curve": "easeIn"
          },
          {
            "level": 0.12
          }
        ]
      },
      "filters": [
        {
          "type": "lowpass",
          "frequencies": [
            {
              "hz": 400,
